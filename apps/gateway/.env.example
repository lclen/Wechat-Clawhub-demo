# Redis 连接地址
WCH_REDIS_URL=redis://127.0.0.1:6379/0

# 默认 Agent ID
WCH_DEFAULT_AGENT_ID=default-agent

# 公共入口基础 URL（替换为你的服务器地址）
WCH_PUBLIC_ENTRY_BASE_URL=http://your-server-ip:8300

# Dify 知识库配置（可选，用于知识库问答）
WCH_DIFY_BASE_URL=http://your-dify-server:3000/v1
WCH_DIFY_API_KEY=app-your-dify-api-key

# 内置模型配置（使用 OpenAI 兼容接口，支持 DashScope、Ollama 等）
WCH_BUILTIN_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
WCH_BUILTIN_MODEL_API_KEY=your-model-api-key
WCH_BUILTIN_MODEL_NAME=qwen-plus

# 微信接入配置（ilink 平台）
WCH_WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
WCH_WECHAT_TOKEN=your-wechat-token

# 微信公众号配置（可选）
WCH_WECHAT_MP_APP_ID=your-mp-app-id
WCH_WECHAT_MP_APP_SECRET=your-mp-app-secret
WCH_WECHAT_MP_TOKEN=your-mp-token
WCH_WECHAT_MP_ENCODING_AES_KEY=your-encoding-aes-key
WCH_WECHAT_MP_HTTP_PROXY=

# 节点分发模式（true=主机只分发，false=主机也可处理）
WCH_DISPATCH_MODE_ENABLED=false

# 节点 Token 配置（JSON 格式）
WCH_NODE_TOKENS='{"agent-1": "your-node-token"}'

# 控制台连接网关地址
WCH_CONSOLE_GATEWAY_BASE_URL=http://your-server-ip:8300

# 模型参数调优（可选）
WCH_BUILTIN_MODEL_ENABLE_THINKING=false
WCH_BUILTIN_MODEL_TEMPERATURE=0.3
WCH_BUILTIN_MODEL_TOP_P=1.0
WCH_BUILTIN_MODEL_MAX_TOKENS=0

# 公共入口配置（可选）
WCH_PUBLIC_ENTRY_ENABLED=false
WCH_PUBLIC_ENTRY_DISPLAY_NAME=ClawBot 统一入口
WCH_PUBLIC_ENTRY_QR_URL=
WCH_PUBLIC_ENTRY_CONTACT_HINT=
WCH_PUBLIC_ENTRY_NOTES=
WCH_PUBLIC_ENTRY_GREETING_MESSAGE=你好，已成功连接到专属 Claw。
